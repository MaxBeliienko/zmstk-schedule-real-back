# Використовуємо офіційний легкий образ Node.js
FROM node:18-alpine

# Створюємо робочу директорію всередині контейнера
WORKDIR /usr/src/app

# Копіюємо файли конфігурації package.json та package-lock.json (якщо є)
COPY package*.json ./

# Встановлюємо залежності проєкту
RUN npm install

# Копіюємо весь інший код бекенду в контейнер
COPY . .

# Відкриваємо порт нашого додатку (зазвичай 5000 або 8080)
EXPOSE 8080

# Команда для запуску додатку
CMD [ "npm", "start" ]